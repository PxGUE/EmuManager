# ==============================================
# EmuManager v0.1.5 alpha — .gitignore
# ==============================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Entornos virtuales ---
venv/
.venv/
env/
.env/
.env

# --- Datos de usuario (NO subir al repo) ---
data/
*.json

# --- Logs ---
*.log

# --- Media descargada (carátulas, fondos, etc.) ---
media/artwork/
media/backgrounds/

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Archivos temporales ---
*.tmp
*.bak
*.orig

# --- Releases (Binarios) ---
releases/

# --- Scripts internos ---
tools/
